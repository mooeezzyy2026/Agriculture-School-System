<!DOCTYPE html>
<html lang="en">
<head>
<header>
            <h1>{% block header_title %}Dashboard{% endblock %}</h1>
            <div style="display: flex; align-items: center; gap: 1.5rem;">
                <!-- Live Date and Time -->
                <div style="font-size: 0.85rem; color: #64748b; text-align: right;">
                    <div id="current-date" style="font-weight: 600;"></div>
                    <div id="current-time" style="font-weight: 700; color: var(--primary-hover);"></div>
                </div>

                {% if user.is_authenticated %}
                <div class="header-user-badge">
                    <div class="avatar-circle">
                        {{ user.get_initials }}
                    </div>
                    <div style="font-weight: 500; font-size: 0.9rem; color: #475569;">
                        User: <span style="font-weight: 700; color: var(--primary-hover);">{{ user.get_full_name|default:user.username }}</span>
                    </div>
                </div>
                {% endif %}
            </div>
        </header>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Agriculture School{% endblock %}</title>
    <style>
        :root {
            --primary-color: #10b981; /* Emerald Green */
            --primary-hover: #059669;
            --background-color: #f0fdf4;
            --card-background: #ffffff;
            --text-color: #1e293b;
            --border-color: #cbd5e1;
            --sidebar-gradient: linear-gradient(180deg, #064e3b 0%, #1e3a8a 100%);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: var(--background-color);
            color: var(--text-color);
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
        }

        aside {
            background: var(--sidebar-gradient);
            padding: 2.5rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            position: sticky;
            top: 0;
            height: 100vh;
            color: #ffffff;
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.1);
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        }

        .sidebar-header h2 {
            font-size: 1.15rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.025em;
            line-height: 1.2;
        }

        .sidebar-header h2 span {
            font-weight: 500;
            font-size: 0.85rem;
            color: var(--primary-color);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        aside nav ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        aside nav a, aside nav button.nav-btn {
            text-decoration: none;
            color: #e2e8f0;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            display: block;
            width: 100%;
            text-align: left;
            background: none;
            border: none;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        aside nav a:hover, aside nav button.nav-btn:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: #ffffff;
            transform: translateX(4px);
        }

        .dropdown-trigger {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .arrow-icon {
            font-size: 0.65rem;
            transition: transform 0.3s ease;
        }

        .dropdown-container {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            list-style: none;
            padding-left: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            background-color: rgba(255, 255, 255, 0.03);
            border-radius: 0.375rem;
        }

        .dropdown-container.open {
            max-height: 200px;
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
            margin-top: 0.25rem;
        }

        .dropdown-container a {
            font-size: 0.85rem;
            color: #cbd5e1;
        }

        main {
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            overflow-y: auto;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(16, 185, 129, 0.15);
            padding-bottom: 1rem;
        }

        header h1 {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.025em;
            color: var(--primary-hover);
        }

        .kpi-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            width: 100%;
        }

        .kpi-card {
            background-color: var(--card-background);
            border-radius: 0.75rem;
            padding: 1.5rem;
            border: 1px solid rgba(16, 185, 129, 0.15);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            transition: all 0.3s ease;
        }

        .kpi-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 12px -3px rgba(16, 185, 129, 0.1);
        }

        .kpi-value {
            font-size: 1.85rem;
            font-weight: 800;
            color: var(--primary-hover);
        }

        .kpi-label {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.05em;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background-color: var(--card-background);
            border: 1px solid rgba(16, 185, 129, 0.15);
            border-radius: 0.85rem;
            padding: 2rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.15), 0 4px 6px -2px rgba(16, 185, 129, 0.05);
            border-color: var(--primary-color);
        }

        .card h3 {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--primary-hover);
            margin-bottom: 0.5rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th, td {
            text-align: left;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid rgba(16, 185, 129, 0.1);
        }

        th {
            background-color: #f0fdf4;
            font-weight: 600;
            color: var(--primary-hover);
        }

        .header-user-badge {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background-color: #f0fdf4;
            padding: 0.4rem 1rem 0.4rem 0.4rem;
            border-radius: 2rem;
            border: 1px solid rgba(16, 185, 129, 0.15);
        }

        .avatar-circle {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: var(--primary-color);
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.85rem;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.2);
        }
    </style>
</head>
<body>
    <aside>
        <div class="sidebar-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
                <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
            </svg>
            <h2>Agriculture<br><span>School Portal</span></h2>
        </div>
        
        <nav>
            <ul>
                {% if user.is_authenticated %}
                    {% if user.is_student %}
                        <li><a href="{% url 'student_dashboard' %}">My Dashboard</a></li>
                        <li><a href="{% url 'student_timetable' %}">📅 My Timetable</a></li>
                    {% elif user.is_teacher %}
                        <li><a href="{% url 'teacher_dashboard' %}">Teacher Dashboard</a></li>
                        <li><a href="{% url 'teacher_timetable' %}">📅 My Schedule</a></li>
                        <li><a href="{% url 'student_directory' %}">👨‍🎓 Student Directory</a></li>
                    {% endif %}
                    
                    <li><a href="{% url 'analytics' %}">📊 Insights & Analytics</a></li>
                    
                    {% if user.is_teacher %}
                        <li><a href="{% url 'homework_hub' %}">📚 Homework Hub</a></li>
                    {% endif %}
                    
                    <li><a href="{% url 'messages' %}">💬 Messages</a></li>
                    
                    <!-- NEW ASSIGNMENTS DROPDOWN FOR STUDENTS -->
                    {% if user.is_student %}
                    <li>
                        <button class="nav-btn dropdown-trigger" onclick="toggleAssignmentsDropdown()" style="padding: 0.75rem 1rem;">
                            <span>📝 Assignments</span>
                            <span id="assignments-arrow" class="arrow-icon">▼</span>
                        </button>
                        <ul id="assignments-menu" class="dropdown-container">
                            <li><a href="{% url 'homework_hub' %}">Submit Assignment</a></li>
                            <li><a href="{% url 'homework_hub' %}">Submit Homework</a></li>
                        </ul>
                    </li>
                    
                    <li><a href="{% url 'student_fees' %}">💰 Fees & Dues</a></li>
                    {% endif %}

                    <li><a href="{% url 'admin:index' %}">System Settings</a></li>
                    
                    <!-- Secure, Inline-styled Logout Button Form -->
                    <li>
                        <form action="{% url 'logout' %}" method="post" style="width: 100%; margin: 0; padding: 0;">
                            {% csrf_token %}
                            <button type="submit" style="background: none; border: none; color: #e2e8f0; padding: 0.75rem 1rem; border-radius: 0.5rem; display: block; width: 100%; text-align: left; font-family: inherit; font-size: 0.95rem; font-weight: 500; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'; this.style.color='#ffffff'; this.style.transform='translateX(4px)';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#e2e8f0'; this.style.transform='none';">
                                🚪 Log Out
                            </button>
                        </form>
                    </li>
                {% endif %}
            </ul>
        </nav>
    </aside>

    <main class="animate-fade-in-up">
        <header>
            <h1>{% block header_title %}Dashboard{% endblock %}</h1>
            {% if user.is_authenticated %}
            <div class="header-user-badge">
                <div class="avatar-circle">
                    {{ user.get_initials }}
                </div>
                <div style="font-weight: 500; font-size: 0.9rem; color: #475569;">
                    User: <span style="font-weight: 700; color: var(--primary-hover);">{{ user.get_full_name|default:user.username }}</span>
                </div>
            </div>
            {% endif %}
        </header>
        
        <!-- Toast alerts -->
        {% if messages %}
            <div style="margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; width: 100%;">
                {% for message in messages %}
                    <div style="padding: 0.85rem; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 600; text-align: center; border: 1px solid;
                        {% if message.tags == 'error' %}
                            background-color: #fef2f2; border-color: #fca5a5; color: #b91c1c;
                        {% else %}
                            background-color: #f0fdf4; border-color: #bbf7d0; color: #15803d;
                        {% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <section class="content">
            {% block content %}{% endblock %}
        </section>
    </main>

    <script>
        function toggleDropdown() {
            const menu = document.getElementById('dropdown-menu');
            const arrow = document.getElementById('dropdown-arrow');
            menu.classList.toggle('open');
            if (menu.classList.contains('open')) {
                arrow.style.transform = 'rotate(180deg)';
            } else {
                arrow.style.transform = 'rotate(0deg)';
            }
        }

        // New Javascript Toggle Trigger for the Assignments Dropdown
        function toggleAssignmentsDropdown() {
            const menu = document.getElementById('assignments-menu');
            const arrow = document.getElementById('assignments-arrow');
            menu.classList.toggle('open');
            if (menu.classList.contains('open')) {
                arrow.style.transform = 'rotate(180deg)';
            } else {
                arrow.style.transform = 'rotate(0deg)';
            }

        }
    </script>
</body>
</html>
